{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ControlDeck (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/ControlDeck/bin/Debug/net8.0-windows/win-x64/ControlDeck.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ControlDeck/bin/Debug/net8.0-windows/win-x64",
            "stopAtEntry": false,
            "console": "internalConsole",
            "exceptionOptions": [
                {
                    "exceptionCategory": "System.TimeoutException",
                    "breakMode": "unhandled"
                },
                {
                    "exceptionCategory": "System.OperationCanceledException",
                    "breakMode": "unhandled"
                }
            ]
        }
    ]
}
